{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables core and booking image save permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-mkdir",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$DESKTOP/ManilaPrime" },
        { "path": "$DESKTOP/ManilaPrime/*" },
        { "path": "$DESKTOP/ManilaPrime/Bookings" },
        { "path": "$DESKTOP/ManilaPrime/Bookings/*" }
      ]
    }
  ]
}